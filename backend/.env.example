# 실제 항공권 검색 연동 시 backend에서만 사용하세요. 프론트엔드에 노출 금지.
# 값이 비어 있으면 /api/flights/search는 fixture 후보를 반환합니다.
AMADEUS_CLIENT_ID=
AMADEUS_CLIENT_SECRET=
AMADEUS_BASE_URL=https://test.api.amadeus.com

# 선택 연동 후보
AVIATIONSTACK_API_KEY=
DATABASE_URL=sqlite:///./flight_booking_helper.db

# Render 배포 시 Vercel production origin을 넣으세요. 쉼표로 여러 origin을 지정할 수 있습니다.
FRONTEND_ORIGIN=http://localhost:5173
